# Local PostgreSQL — runs on your machine
PGHOST=localhost
PGPORT=5432
PGDATABASE=timepoverty
PGUSER=tpm_app
PGPASSWORD=__REPLACE_ME__
PGSSLMODE=disable

# --- Backend auth secrets (consumed by backend-api/application.yml) --------------
# JWT signing key: REQUIRED in production. >= 32 chars of high entropy. If unset the
# backend mints a random key per boot (tokens reset on every restart) — safe, but
# users get logged out each deploy, so set a stable secret. Generate one with:
#   openssl rand -base64 48
# Single-quote in .env so `source` keeps special characters literal.
APP_AUTH_JWT_SECRET='__GENERATE_A_LONG_RANDOM_SECRET__'

# Seeded admin account. If the password is left blank the backend generates a random
# one and logs it ONCE at first startup (read it from the backend log). Set both to
# control the credentials. Never commit real values.
APP_ADMIN_EMAIL='admin@gmail.com'
APP_ADMIN_PASSWORD='__SET_A_STRONG_ADMIN_PASSWORD__'

# Optional: AI explanations via Google Gemini (left blank ⇒ deterministic fallback).
# GEMINI_API_KEY=''
